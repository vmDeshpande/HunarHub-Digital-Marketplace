# Development Environment Variables
# Copy this file to .env.local and fill in your values

# MongoDB - Use MongoDB Atlas Free Tier
MONGODB_URI=mongodb+srv://dev_user:dev_password@test-cluster.mongodb.net/hunar_hub_dev?retryWrites=true&w=majority

# NextAuth - Generate secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-32-character-secret-here

# Google OAuth - Get from https://console.cloud.google.com
# 1. Create a new project
# 2. Create OAuth 2.0 credentials (Desktop application)
# 3. Add http://localhost:3000 to authorized origins
# 4. Add http://localhost:3000/api/auth/callback/google to authorized redirect URIs
GOOGLE_CLIENT_ID=your-dev-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-dev-google-client-secret

# UploadThing - Get from https://uploadthing.com
# Use test token for development
UPLOADTHING_TOKEN=sk_test_your-uploadthing-test-token

# Development Flag
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000/api
